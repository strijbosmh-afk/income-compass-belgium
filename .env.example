VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-or-publishable-key"

# Supabase Edge Function secrets, set with `supabase secrets set`.
# At least one AI allowlist variable is required by the extraction functions.
LOVABLE_API_KEY="your-lovable-ai-gateway-key"
AI_ALLOWED_USER_IDS="comma-separated-supabase-user-ids"
AI_ALLOWED_EMAILS="comma-separated-login-emails"
